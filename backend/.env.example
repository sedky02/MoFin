DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mofin?schema=public"
JWT_ACCESS_SECRET="replace-me-access"
JWT_REFRESH_SECRET="replace-me-refresh"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="30d"
PORT=3000

# --- OAuth 2.1 authorization server (MCP custom connector for claude.ai) ---
# Public base URL of THIS backend. In dev it is localhost; for claude.ai set it
# to the public HTTPS tunnel host. Must exactly match the token issuer/audience.
OAUTH_ISSUER="http://localhost:3000"
# Canonical MCP resource URL (token audience). Defaults to ${OAUTH_ISSUER}/api/v1/mcp.
# OAUTH_RESOURCE_URI="http://localhost:3000/api/v1/mcp"
# Where users log in (the Next.js web app) for the login bridge.
WEB_URL="http://localhost:3001"
# Comma-separated host allowlist for DCR redirect_uris.
OAUTH_ALLOWED_REDIRECT_HOSTS="claude.ai,claude.com"

# --- Google sign-in (optional; /auth/google returns 503 until all are set) ---
# GOOGLE_CLIENT_ID="...apps.googleusercontent.com"
# GOOGLE_CLIENT_SECRET="..."
# GOOGLE_TOKEN_URL="https://oauth2.googleapis.com/token"
