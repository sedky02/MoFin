generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AccountType {
  CASH
  BANK
  SAVINGS
  CRYPTO
}

enum CategoryType {
  INCOME
  EXPENSE
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
}

enum DraftStatus {
  PENDING
  APPROVED
  REJECTED
}

enum LedgerDirection {
  DEBIT
  CREDIT
}

enum RecurringInterval {
  MONTHLY
  YEARLY
}

enum RecurringStatus {
  ACTIVE
  CANCELLED
}

enum BudgetPeriod {
  MONTHLY
  YEARLY
}

enum GoalType {
  BALANCE
  INCOME
  EXPENSE
}

enum GoalRecurrenceUnit {
  MONTH
  YEAR
}

enum GoalStatus {
  IN_PROGRESS
  ACHIEVED
  FAILED
}

model User {
  id                 String              @id @default(uuid())
  email              String              @unique
  passwordHash       String?
  displayName        String?
  googleId           String?             @unique
  settings           Json                @default("{}")
  apiKeys            ApiKey[]
  accounts           Account[]
  categories         Category[]
  transactions       Transaction[]
  transactionItems   TransactionItem[]
  drafts             DraftTransaction[]
  budgets            Budget[]
  goals              Goal[]
  analyticsCaches    AnalyticsCache[]
  oauthCodes         AuthorizationCode[]
  oauthRefreshTokens OAuthRefreshToken[]
  oauthGrants        OAuthGrant[]
  authSessions       AuthSession[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
}

model ApiKey {
  id         String    @id @default(uuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  keyHash    String    @unique
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
}

model Account {
  id               String            @id @default(uuid())
  userId           String
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  name             String
  type             AccountType
  currency         String
  metadata         Json              @default("{}")
  archivedAt       DateTime?
  transactionItems TransactionItem[]
  goals            Goal[]
  recurringFrom    Transaction[]     @relation("RecurringFromAccount")
  recurringTo      Transaction[]     @relation("RecurringToAccount")
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([userId, currency])
}

model Category {
  id               String            @id @default(uuid())
  userId           String?
  user             User?             @relation(fields: [userId], references: [id], onDelete: Cascade)
  name             String
  type             CategoryType
  color            String?
  icon             String?
  transactions     Transaction[]
  transactionItems TransactionItem[]
  budgets          Budget[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@unique([userId, name, type])
}

model Transaction {
  id          String            @id @default(uuid())
  userId      String
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId  String?
  category    Category?         @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  draftId     String?           @unique
  draft       DraftTransaction? @relation(fields: [draftId], references: [id], onDelete: SetNull)
  type        TransactionType
  description String
  currency    String
  occurredAt  DateTime
  items       TransactionItem[]

  // Recurrence template fields — only populated on the root transaction that
  // started the series (parentTransactionId == null && isRecurring == true).
  // Kept separate from the root's own ledger-affecting fields (its existing
  // TransactionItem rows) so editing the series never mutates a past ledger entry.
  isRecurring            Boolean            @default(false)
  recurringInterval      RecurringInterval?
  recurringStatus        RecurringStatus?
  recurringEndDate       DateTime?
  nextOccurrenceAt       DateTime?
  recurringAmount        Decimal?           @db.Decimal(18, 4)
  recurringFromAccountId String?
  recurringFromAccount   Account?           @relation("RecurringFromAccount", fields: [recurringFromAccountId], references: [id], onDelete: Restrict)
  recurringToAccountId   String?
  recurringToAccount     Account?           @relation("RecurringToAccount", fields: [recurringToAccountId], references: [id], onDelete: Restrict)

  // Links a generated occurrence back to the root transaction of its series.
  parentTransactionId  String?
  parentTransaction    Transaction?  @relation("RecurringOccurrences", fields: [parentTransactionId], references: [id], onDelete: SetNull)
  recurringOccurrences Transaction[] @relation("RecurringOccurrences")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, occurredAt])
  @@index([userId, categoryId])
  @@index([isRecurring, recurringStatus, nextOccurrenceAt])
  @@index([parentTransactionId])
}

model TransactionItem {
  id            String          @id @default(uuid())
  userId        String
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactionId String
  transaction   Transaction     @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  accountId     String
  account       Account         @relation(fields: [accountId], references: [id], onDelete: Restrict)
  categoryId    String?
  category      Category?       @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  direction     LedgerDirection
  amount        Decimal         @db.Decimal(18, 4)
  currency      String
  memo          String?
  createdAt     DateTime        @default(now())

  @@index([userId, accountId, createdAt])
  @@index([transactionId])
}

model DraftTransaction {
  id              String       @id @default(uuid())
  userId          String
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  transaction     Transaction?
  rawInput        String
  parsedData      Json
  confidenceScore Decimal      @db.Decimal(5, 4)
  status          DraftStatus  @default(PENDING)
  rejectionReason String?
  approvedAt      DateTime?
  rejectedAt      DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([userId, status, createdAt])
}

model AnalyticsCache {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cacheKey   String
  payload    Json
  computedAt DateTime @default(now())
  expiresAt  DateTime

  @@unique([userId, cacheKey])
}

model Budget {
  id         String       @id @default(uuid())
  userId     String
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId String?
  category   Category?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  name       String
  amount     Decimal      @db.Decimal(18, 4)
  currency   String
  period     BudgetPeriod @default(MONTHLY)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
}

model Goal {
  id             String              @id @default(uuid())
  userId         String
  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId      String
  account        Account             @relation(fields: [accountId], references: [id], onDelete: Cascade)
  name           String
  type           GoalType
  targetAmount   Decimal             @db.Decimal(18, 4)
  isRecurring    Boolean             @default(false)
  recurrenceUnit GoalRecurrenceUnit?
  periodStart    DateTime
  periodEnd      DateTime?
  archivedAt     DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  instances      GoalInstance[]

  @@index([userId, archivedAt])
}

model GoalInstance {
  id             String     @id @default(uuid())
  goalId         String
  goal           Goal       @relation(fields: [goalId], references: [id], onDelete: Cascade)
  periodStart    DateTime
  periodEnd      DateTime
  targetAmount   Decimal    @db.Decimal(18, 4)
  progressAmount Decimal    @default(0) @db.Decimal(18, 4)
  status         GoalStatus @default(IN_PROGRESS)
  computedAt     DateTime   @default(now())

  @@unique([goalId, periodStart])
  @@index([status, periodEnd])
}

// --- OAuth 2.1 authorization server (MCP custom connector for claude.ai) ---

// A client registered via Dynamic Client Registration (RFC 7591).
// claude.ai is a public PKCE client, so there is no client secret.
model OAuthClient {
  id                      String   @id @default(uuid())
  clientId                String   @unique
  clientName              String?
  redirectUris            String[]
  grantTypes              String[]
  responseTypes           String[]
  scope                   String?
  tokenEndpointAuthMethod String   @default("none")
  createdAt               DateTime @default(now())
}

// Single-use authorization code issued by /authorize and exchanged at /token.
// `code` stores a hash of the value handed back in the redirect, never the raw code.
model AuthorizationCode {
  id                  String    @id @default(uuid())
  code                String    @unique
  clientId            String
  userId              String
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  redirectUri         String
  codeChallenge       String
  codeChallengeMethod String
  scope               String
  resource            String?
  usedAt              DateTime?
  expiresAt           DateTime
  createdAt           DateTime  @default(now())

  @@index([userId])
}

// Persisted, rotating refresh token. `tokenHash` is the hash of the opaque token.
// `familyId` groups rotations so that reuse of a rotated token revokes the whole family.
model OAuthRefreshToken {
  id          String    @id @default(uuid())
  tokenHash   String    @unique
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientId    String
  scope       String
  resource    String?
  familyId    String
  rotatedToId String?
  revokedAt   DateTime?
  expiresAt   DateTime
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([familyId])
}

// Remembered user consent for a (user, client) pair so consent is shown only once.
model OAuthGrant {
  id       String @id @default(uuid())
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientId String
  scope    String

  @@unique([userId, clientId])
}

// First-party backend session created by the cross-origin login bridge.
// `sessionToken` stores a hash of the value placed in the mofin_as_session cookie.
model AuthSession {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt    DateTime
  createdAt    DateTime @default(now())
}
